{
  "description": "Dependency reference — use setup/init.mjs to install only what your selection needs",
  "note": "Run: node essentials/setup/init.mjs --preset dashboard — it prints the exact npm install command",
  "sharedDeps": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^1.21.0"
  },
  "motionDeps": {
    "motion": "^12.10.0",
    "react-use-measure": "^2.1.7"
  },
  "radixDeps": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.1.8"
  },
  "presets": {
    "minimal": "node essentials/setup/init.mjs --preset minimal",
    "dashboard": "node essentials/setup/init.mjs --preset dashboard",
    "marketing": "node essentials/setup/init.mjs --preset marketing"
  },
  "shadcnInit": "npx shadcn@latest init",
  "manifest": "setup/manifest.json"
}
